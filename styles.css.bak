/* ==========================================
   AXIS // minimal black + dune system
   ========================================== */

:root {
    --bg-void: #020203;
    --bg-surface: #060607;
    --bg-surface-glass: rgba(6, 6, 7, 0.72);
    --bg-card: #0b0b0d;
    --bg-card-hover: #0f1012;

    --hud-violet: #c89c64;
    --hud-violet-glow: rgba(200, 156, 100, 0.18);
    --hud-violet-subtle: rgba(200, 156, 100, 0.08);

    --hud-cyan: #b7bec8;
    --hud-cyan-glow: rgba(183, 190, 200, 0.14);
    --hud-cyan-subtle: rgba(183, 190, 200, 0.06);

    --hud-optimal: #a2b896;
    --hud-warning: #d1b07b;
    --hud-critical: #c27d68;

    --text-main: #f7f4ee;
    --text-muted: #8c8a84;
    --text-dark: #020203;

    --line-soft: rgba(255, 255, 255, 0.06);
    --line-strong: rgba(255, 255, 255, 0.11);
    --surface-soft: rgba(255, 255, 255, 0.025);
    --surface-softer: rgba(255, 255, 255, 0.018);
    --shadow-lg: 0 28px 90px rgba(0, 0, 0, 0.52);
    --shadow-md: 0 16px 42px rgba(0, 0, 0, 0.34);

    --font-mono: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', monospace;
    --font-body: Inter, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;

    --clip-corner: none;
    --clip-corner-sm: none;
}

* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
    -webkit-tap-highlight-color: transparent;
    user-select: none;
}

input,
textarea,
select,
[contenteditable="true"],
.select-text {
    user-select: text;
    -webkit-user-select: text;
}

html {
    scroll-behavior: smooth;
}

html,
body {
    text-rendering: optimizeLegibility;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
}

body {
    background-color: var(--bg-void);
    color: var(--text-main);
    font-family: var(--font-body);
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: hidden;
    position: relative;
    background-image:
        radial-gradient(circle at 50% 0%, rgba(255,255,255,0.035) 0%, transparent 20%),
        radial-gradient(circle at 50% 14%, rgba(200, 156, 100, 0.08) 0%, transparent 24%),
        linear-gradient(180deg, #070708 0%, #030304 62%, #020203 100%);
    background-attachment: fixed;
}

body::before {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0.16;
    background:
        radial-gradient(circle at center 18%, rgba(255,255,255,0.03), transparent 34%),
        linear-gradient(180deg, transparent 0%, rgba(255,255,255,0.01) 100%);
}

body::after {
    content: "";
    position: fixed;
    left: 50%;
    bottom: -6vh;
    width: min(1100px, 120vw);
    height: min(480px, 46vh);
    transform: translateX(-50%);
    pointer-events: none;
    z-index: 0;
    opacity: 0.24;
    background:
        radial-gradient(ellipse at center, rgba(255,255,255,0.1) 0%, transparent 54%),
        radial-gradient(circle at 20% 68%, rgba(255,255,255,0.09) 0 1px, transparent 1.6px),
        radial-gradient(circle at 80% 60%, rgba(255,255,255,0.08) 0 1px, transparent 1.6px);
    background-size: 100% 100%, 16px 16px, 18px 18px;
    filter: blur(1px);
    mask-image: linear-gradient(180deg, transparent 0%, rgba(0,0,0,0.2) 16%, rgba(0,0,0,1) 42%, rgba(0,0,0,0.12) 100%);
}

::-webkit-scrollbar { width: 8px; height: 8px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb {
    background: rgba(255, 255, 255, 0.10);
    border-radius: 999px;
}
::-webkit-scrollbar-thumb:hover {
    background: rgba(215, 154, 82, 0.32);
}

/* ==========================================
   top shell
   ========================================== */

header.hud-bar {
    width: min(1520px, calc(100% - 36px));
    margin: 18px auto 0;
    padding: 4px 6px;
    display: grid;
    grid-template-columns: minmax(240px, 1fr) auto minmax(180px, 1fr);
    align-items: center;
    gap: 18px;
    background: transparent;
    border: none;
    position: sticky;
    top: 10px;
    z-index: 100;
}

.hud-brand {
    display: flex;
    align-items: center;
    gap: 14px;
    cursor: pointer;
    flex-shrink: 0;
    min-width: 0;
    padding-left: 6px;
}

.hud-reticle-icon {
    width: 32px;
    height: 32px;
    color: var(--hud-violet);
    opacity: 0.94;
    filter: drop-shadow(0 0 6px rgba(215, 154, 82, 0.16));
    animation: reticle-float 7.2s ease-in-out infinite;
    flex-shrink: 0;
}

@keyframes reticle-float {
    0%, 100% { transform: translateY(0) scale(1); opacity: 0.88; filter: drop-shadow(0 0 4px rgba(215, 154, 82, 0.12)); }
    50% { transform: translateY(-1px) scale(0.992); opacity: 1; filter: drop-shadow(0 0 10px rgba(215, 154, 82, 0.2)); }
}

.hud-brand-text {
    display: flex;
    flex-direction: column;
    gap: 6px;
    min-width: 0;
}

.hud-brand-title-row {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 1.08rem;
    font-weight: 650;
    letter-spacing: 0.06em;
}

.hud-version-badge {
    font-size: 0.64rem;
    color: var(--text-muted);
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    padding: 4px 9px;
    border-radius: 999px;
    letter-spacing: 0.10em;
}

.hud-meta-row {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
}

.hud-age-chip,
.hud-sync-chip {
    display: inline-flex;
    align-items: center;
    min-height: 28px;
    padding: 6px 10px;
    border-radius: 999px;
    border: 1px solid rgba(255,255,255,0.08);
    background: rgba(255,255,255,0.03);
    color: var(--text-muted);
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.10em;
    white-space: nowrap;
}

.hud-sync-chip {
    transition: color 0.22s cubic-bezier(0.16, 1, 0.3, 1), border-color 0.22s cubic-bezier(0.16, 1, 0.3, 1), background 0.22s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.22s cubic-bezier(0.16, 1, 0.3, 1);
}

.hud-sync-chip[data-state="busy"] {
    color: var(--hud-violet);
    border-color: rgba(215, 154, 82, 0.18);
    background: rgba(215, 154, 82, 0.08);
    box-shadow: 0 0 0 1px rgba(215, 154, 82, 0.04) inset;
}

.hud-sync-chip[data-state="warn"] {
    color: var(--hud-warning);
    border-color: rgba(217, 171, 114, 0.22);
    background: rgba(217, 171, 114, 0.07);
}

.hud-sync-chip[data-state="idle"] {
    color: var(--text-muted);
}

.hud-nav-tabs {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 4px;
    padding: 6px;
    background: rgba(10,10,12,0.72);
    border: 1px solid rgba(255,255,255,0.06);
    backdrop-filter: blur(22px) saturate(120%);
    -webkit-backdrop-filter: blur(22px) saturate(120%);
    border-radius: 999px;
    flex-wrap: nowrap;
    box-shadow: 0 12px 34px rgba(0,0,0,0.28), inset 0 1px 0 rgba(255,255,255,0.025);
}

.nav-tab-btn {
    background: transparent;
    border: 1px solid transparent;
    color: rgba(247,244,238,0.64);
    padding: 10px 16px;
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 0.77rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    cursor: pointer;
    transition:
        background 0.2s cubic-bezier(0.16, 1, 0.3, 1),
        color 0.2s cubic-bezier(0.16, 1, 0.3, 1),
        border-color 0.2s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.2s cubic-bezier(0.16, 1, 0.3, 1),
        box-shadow 0.2s cubic-bezier(0.16, 1, 0.3, 1);
}

.nav-tab-btn:hover {
    background: rgba(255,255,255,0.035);
    color: var(--text-main);
    border-color: rgba(255,255,255,0.05);
    transform: translateY(-1px);
}

.nav-tab-btn.active {
    color: var(--text-main);
    border-color: rgba(255,255,255,0.06);
    background: linear-gradient(180deg, rgba(255,255,255,0.065), rgba(255,255,255,0.035));
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.03), 0 10px 24px rgba(0,0,0,0.2);
}

.hud-time-container {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 18px;
    flex-shrink: 0;
    min-width: 140px;
}

.hud-time-container > div {
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(10,10,12,0.72);
    border: 1px solid rgba(255,255,255,0.05);
    backdrop-filter: blur(22px) saturate(120%);
    -webkit-backdrop-filter: blur(22px) saturate(120%);
    box-shadow: 0 12px 34px rgba(0,0,0,0.28), inset 0 1px 0 rgba(255,255,255,0.025);
}

.hud-time-container > div {
    padding: 10px 14px;
    border-radius: 999px;
    background: rgba(10,10,12,0.72);
    border: 1px solid rgba(255,255,255,0.05);
    backdrop-filter: blur(22px) saturate(120%);
    -webkit-backdrop-filter: blur(22px) saturate(120%);
    box-shadow: 0 12px 34px rgba(0,0,0,0.28), inset 0 1px 0 rgba(255,255,255,0.025);
}

.live-clock-text {
    font-size: 1.05rem;
    font-weight: 650;
    color: var(--text-main);
    letter-spacing: 0.04em;
    text-align: right;
}

.live-date-text {
    font-size: 0.70rem;
    color: var(--text-muted);
    letter-spacing: 0.10em;
    text-transform: uppercase;
    text-align: right;
    margin-top: 3px;
}

/* ==========================================
   workspace + transitions
   ========================================== */

main.axis-workspace {
    flex: 1;
    padding: 34px 18px 56px;
    max-width: 1480px;
    margin: 0 auto;
    width: 100%;
    position: relative;
    z-index: 1;
}

.module-page {
    display: none;
    opacity: 0;
    transform: translateY(10px) scale(0.996);
    transform-origin: top center;
    will-change: opacity, transform;
    transition:
        opacity 0.32s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.32s cubic-bezier(0.16, 1, 0.3, 1);
}

.module-page.active {
    display: flex;
    flex-direction: column;
    gap: 34px;
    opacity: 1;
    transform: translateY(0) scale(1);
}

/* ==========================================
   surfaces
   ========================================== */

.cockpit-card {
    background: linear-gradient(180deg, rgba(11, 11, 13, 0.88), rgba(7, 7, 8, 0.94));
    border: 1px solid rgba(255,255,255,0.045);
    border-radius: 34px;
    padding: 28px;
    display: flex;
    flex-direction: column;
    gap: 18px;
    position: relative;
    transition:
        border-color 0.18s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.18s cubic-bezier(0.16, 1, 0.3, 1),
        box-shadow 0.18s cubic-bezier(0.16, 1, 0.3, 1),
        background 0.18s cubic-bezier(0.16, 1, 0.3, 1);
    box-shadow: 0 22px 60px rgba(0, 0, 0, 0.42), inset 0 1px 0 rgba(255,255,255,0.018);
    overflow: hidden;
}

.cockpit-card::before {
    content: "";
    position: absolute;
    inset: 0;
    pointer-events: none;
    background: radial-gradient(circle at top center, rgba(255,255,255,0.028), transparent 34%);
}

@media (hover: hover) and (pointer: fine) {
    .cockpit-card:hover {
        border-color: rgba(255,255,255,0.075);
        background: linear-gradient(180deg, rgba(12, 12, 14, 0.92), rgba(8, 8, 9, 0.96));
        box-shadow: 0 28px 72px rgba(0,0,0,0.5), inset 0 1px 0 rgba(255,255,255,0.024);
        transform: translateY(-1px);
    }
}

.cockpit-card > * {
    position: relative;
    z-index: 1;
}

.cockpit-header {
    font-size: 0.86rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: var(--text-main);
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-bottom: 4px;
    text-transform: none;
    gap: 14px;
    flex-wrap: wrap;
}

.cockpit-card-flat {
    background: rgba(255,255,255,0.018);
    border: 1px solid rgba(255,255,255,0.045);
    border-radius: 24px;
    box-shadow: none;
}

.cockpit-card-flat:hover {
    transform: none;
    box-shadow: none;
    background: rgba(255,255,255,0.024);
}

/* ==========================================
   buttons + inputs
   ========================================== */

.tactical-btn {
    background: rgba(255,255,255,0.028);
    border: 1px solid rgba(255,255,255,0.06);
    color: var(--text-main);
    padding: 10px 16px;
    border-radius: 999px;
    font-family: var(--font-body);
    font-size: 0.76rem;
    font-weight: 500;
    letter-spacing: 0.03em;
    cursor: pointer;
    transition:
        background 0.2s cubic-bezier(0.16, 1, 0.3, 1),
        border-color 0.2s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.2s cubic-bezier(0.16, 1, 0.3, 1),
        box-shadow 0.2s cubic-bezier(0.16, 1, 0.3, 1),
        color 0.2s cubic-bezier(0.16, 1, 0.3, 1);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    text-transform: uppercase;
    min-height: 40px;
}

@media (hover: hover) and (pointer: fine) {
    .tactical-btn:hover {
        background: rgba(255,255,255,0.05);
        border-color: rgba(255,255,255,0.085);
        transform: translateY(-1px);
        box-shadow: 0 12px 24px rgba(0,0,0,0.24);
    }
}

.tactical-btn:active {
    transform: scale(0.984);
}

.tactical-btn.active,
.tactical-btn.tactical-btn-primary {
    color: #050506;
    border-color: rgba(255,255,255,0.22);
    background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(244,241,235,0.92));
    box-shadow: inset 0 1px 0 rgba(255,255,255,0.08), 0 14px 30px rgba(0,0,0,0.28);
}

.tactical-btn.cyan {
    border-color: rgba(173, 181, 191, 0.18);
}

.tactical-btn.cyan:hover,
.tactical-btn.cyan.active {
    background: rgba(173, 181, 191, 0.10);
}

.tactical-btn.optimal {
    border-color: rgba(151, 181, 137, 0.18);
}

.tactical-btn.optimal:hover,
.tactical-btn.optimal.active {
    background: rgba(151, 181, 137, 0.10);
}

.tactical-input,
.tactical-select {
    width: 100%;
    min-height: 48px;
    background: rgba(255,255,255,0.022);
    border: 1px solid rgba(255,255,255,0.055);
    color: var(--text-main);
    padding: 14px 16px;
    font-family: var(--font-body);
    font-size: 0.94rem;
    outline: none;
    border-radius: 16px;
    transition:
        border-color 0.18s cubic-bezier(0.16, 1, 0.3, 1),
        box-shadow 0.18s cubic-bezier(0.16, 1, 0.3, 1),
        background 0.18s cubic-bezier(0.16, 1, 0.3, 1),
        transform 0.18s cubic-bezier(0.16, 1, 0.3, 1);
}

textarea.tactical-input {
    min-height: 112px;
    resize: vertical;
}

.tactical-input::placeholder,
.tactical-select::placeholder {
    color: color-mix(in srgb, var(--text-muted) 88%, transparent);
}

.tactical-input:focus,
.tactical-select:focus {
    border-color: rgba(255,255,255,0.1);
    box-shadow: 0 0 0 3px rgba(255,255,255,0.035);
    background: rgba(255,255,255,0.035);
}

input[type="checkbox"],
input[type="radio"] {
    accent-color: var(--hud-violet);
}

/* ==========================================
   greeting + login overlays
   ========================================== */

.boot-overlay {
    position: fixed;
    inset: 0;
    background:
        radial-gradient(circle at 50% 22%, rgba(215,154,82,0.12), transparent 28%),
        linear-gradient(180deg, rgba(14,14,17,0.96), rgba(5,5,6,1));
    z-index: 10000;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 12px;
    transition: opacity 0.8s cubic-bezier(0.16, 1, 0.3, 1), visibility 0.8s cubic-bezier(0.16, 1, 0.3, 1);
    text-align: center;
    padding: 24px;
}

.boot-overlay.hidden {
    opacity: 0;
    pointer-events: none;
    visibility: hidden;
}

.boot-mark {
    font-size: 0.82rem;
    color: var(--text-muted);
    letter-spacing: 0.34em;
    text-transform: uppercase;
}

.boot-greeting {
    font-size: clamp(2.1rem, 7vw, 4.7rem);
    font-weight: 700;
    line-height: 1.04;
    letter-spacing: -0.03em;
    color: var(--text-main);
}

.boot-subline {
    font-size: 0.95rem;
    color: var(--text-muted);
    letter-spacing: 0.06em;
}

.axis-login-overlay {
    position: fixed;
    inset: 0;
    z-index: 9998;
    display: flex;
    justify-content: center;
    align-items: center;
    background: rgba(5, 5, 6, 0.78);
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    transition: opacity 0.28s ease;
}

.axis-login-overlay.hidden {
    opacity: 0;
    pointer-events: none;
}

.axis-login-panel {
    width: min(92vw, 440px);
    background: linear-gradient(180deg, rgba(18, 19, 22, 0.96), rgba(10, 11, 13, 0.98));
    border: 1px solid var(--line-soft);
    border-radius: 32px;
    box-shadow: 0 30px 90px rgba(0,0,0,0.56), inset 0 1px 0 rgba(255,255,255,0.03);
    padding: 30px;
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.axis-login-mark {
    font-size: 0.78rem;
    color: var(--text-muted);
    letter-spacing: 0.32em;
    text-transform: uppercase;
}

.axis-login-title {
    font-size: 1.8rem;
    font-weight: 700;
    letter-spacing: -0.03em;
}

.axis-login-subtitle,
.axis-login-status {
    color: var(--text-muted);
    font-size: 0.85rem;
    line-height: 1.6;
}

.axis-login-status {
    min-height: 20px;
}

/* ==========================================
   utility
   ========================================== */

.stack { display: flex; flex-direction: column; }
.stack-sm { gap: 12px; }
.stack-md { gap: 20px; }
.stack-lg { gap: 32px; }

.row { display: flex; flex-direction: row; align-items: center; }
.row-gap-sm { gap: 8px; }
.row-gap-md { gap: 16px; }
.row-gap-lg { gap: 24px; }

.flex-wrap { flex-wrap: wrap; }
.flex-1 { flex: 1; min-width: 0; }
.flex-shrink-0 { flex-shrink: 0; }

.text-center { text-align: center; }
.text-right { text-align: right; }
.text-muted { color: var(--text-muted); }
.text-main { color: var(--text-main); }
.text-optimal { color: var(--hud-optimal); }
.text-warning { color: var(--hud-warning); }
.text-critical { color: var(--hud-critical); }
.text-accent { color: var(--hud-violet); }
.text-cyan { color: var(--hud-cyan); }

.font-mono { font-family: var(--font-mono); }
.font-body { font-family: var(--font-body); }

.text-sm { font-size: 0.72rem; }
.text-base { font-size: 0.88rem; }
.text-lg { font-size: 1.1rem; }
.text-xl { font-size: 1.5rem; }
.text-2xl { font-size: 2rem; }
.text-3xl { font-size: 2.8rem; }

.font-normal { font-weight: 400; }
.font-medium { font-weight: 500; }
.font-semibold { font-weight: 600; }
.font-bold { font-weight: 700; }

.tracking-wide { letter-spacing: 0.08em; }
.tracking-wider { letter-spacing: 0.12em; }
.uppercase { text-transform: uppercase; }

.w-full { width: 100%; }
.w-auto { width: auto; }

.hidden { display: none !important; }
.invisible { visibility: hidden; }
.visible { visibility: visible; }

.overflow-auto { overflow: auto; }
.overflow-hidden { overflow: hidden; }
.overflow-x-auto { overflow-x: auto; }

.whitespace-nowrap { white-space: nowrap; }
.whitespace-normal { white-space: normal; }
.text-truncate { overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }

.rounded { border-radius: 12px; }
.rounded-lg { border-radius: 18px; }
.rounded-full { border-radius: 999px; }

.opacity-50 { opacity: 0.5; }
.opacity-75 { opacity: 0.75; }

.pointer-events-none { pointer-events: none; }
.cursor-pointer { cursor: pointer; }

.select-none { user-select: none; }

/* ==========================================
   grids
   ========================================== */

.grid { display: grid; gap: 24px; }
.grid-cols-1 { grid-template-columns: repeat(1, minmax(0, 1fr)); }
.grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
.grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
.grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }

@media (min-width: 901px) {
    .md\:grid-cols-2, .md-grid-cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .md\:grid-cols-3, .md-grid-cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .md\:grid-cols-4, .md-grid-cols-4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    .md\:flex-row, .md-flex-row { flex-direction: row; }
    .md\:flex-col, .md-flex-col { flex-direction: column; }
}

/* ==========================================
   metrics / badges / bars / list items
   ========================================== */

.stat-block {
    display: flex;
    flex-direction: column;
    gap: 4px;
}

.stat-label {
    font-family: var(--font-body);
    font-size: 0.78rem;
    color: var(--text-muted);
    letter-spacing: 0.02em;
    text-transform: none;
}

.stat-value {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--text-main);
    line-height: 1.1;
}

.stat-value-lg { font-size: 2.4rem; }
.stat-unit { font-size: 1rem; font-weight: 400; color: var(--text-muted); }

.progress-bar {
    width: 100%;
    height: 8px;
    background: rgba(255, 255, 255, 0.07);
    border-radius: 999px;
    overflow: hidden;
}

.progress-fill {
    height: 100%;
    border-radius: 999px;
    transition: width 0.32s cubic-bezier(0.16, 1, 0.3, 1);
}

.progress-fill-accent { background: var(--hud-violet); }
.progress-fill-optimal { background: var(--hud-optimal); }
.progress-fill-cyan { background: var(--hud-cyan); }
.progress-fill-warning { background: var(--hud-warning); }
.progress-fill-critical { background: var(--hud-critical); }

.form-stack {
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.form-row {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
}

.form-label {
    font-family: var(--font-body);
    font-size: 0.76rem;
    color: var(--text-muted);
    margin-bottom: 6px;
    display: block;
    letter-spacing: 0.01em;
}

.badge {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 11px;
    font-family: var(--font-body);
    font-size: 0.68rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    border-radius: 999px;
    text-transform: none;
}

.badge-accent {
    background: rgba(215, 154, 82, 0.12);
    border: 1px solid rgba(215, 154, 82, 0.20);
    color: var(--hud-violet);
}

.badge-cyan {
    background: rgba(173, 181, 191, 0.12);
    border: 1px solid rgba(173, 181, 191, 0.20);
    color: var(--hud-cyan);
}

.badge-optimal {
    background: rgba(151, 181, 137, 0.12);
    border: 1px solid rgba(151, 181, 137, 0.20);
    color: var(--hud-optimal);
}

.badge-warning {
    background: rgba(217, 171, 114, 0.12);
    border: 1px solid rgba(217, 171, 114, 0.20);
    color: var(--hud-warning);
}

.badge-critical {
    background: rgba(191, 122, 104, 0.12);
    border: 1px solid rgba(191, 122, 104, 0.20);
    color: var(--hud-critical);
}

.badge-muted {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.08);
    color: var(--text-muted);
}

.divider {
    width: 100%;
    height: 1px;
    background: rgba(255,255,255,0.06);
    margin: 8px 0;
}

.divider-vertical {
    width: 1px;
    height: 100%;
    background: rgba(255,255,255,0.06);
    margin: 0 12px;
}

.list-item {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 14px;
    background: rgba(255,255,255,0.018);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 22px;
    transition: background 0.18s ease, border-color 0.18s ease, transform 0.18s ease;
}

.list-item:hover {
    background: rgba(255,255,255,0.026);
    border-color: rgba(255,255,255,0.065);
}


.axis-mini-calendar {
    display: grid;
    grid-template-columns: repeat(7, minmax(0, 1fr));
    gap: 8px;
}

.axis-mini-day {
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 16px;
    padding: 10px;
    min-height: 82px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    gap: 8px;
    transition: border-color 0.18s ease, background 0.18s ease, transform 0.18s ease;
}

.axis-mini-day.today {
    border-color: rgba(215,154,82,0.24);
    background: rgba(215,154,82,0.06);
}

@media (hover: hover) and (pointer: fine) {
    .axis-mini-day:hover {
        transform: translateY(-1px);
        border-color: rgba(255,255,255,0.12);
        background: rgba(255,255,255,0.045);
    }
}

.axis-mini-day-date {
    font-size: 0.78rem;
    font-family: var(--font-mono);
    color: var(--text-main);
}

.axis-mini-day-count {
    display: inline-flex;
    align-items: center;
    width: fit-content;
    padding: 3px 8px;
    border-radius: 999px;
    background: rgba(215,154,82,0.12);
    border: 1px solid rgba(215,154,82,0.18);
    color: var(--hud-violet);
    font-size: 0.62rem;
    font-family: var(--font-mono);
}

.axis-mini-day-preview {
    font-size: 0.66rem;
    color: var(--text-muted);
    line-height: 1.4;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
}

.config-info-wrap {
    word-break: break-word;
    overflow-wrap: anywhere;
    line-height: 1.6;
}

/* ==========================================
   responsive
   ========================================== */

@media (max-width: 900px) {
    header.hud-bar {
        width: calc(100% - 18px);
        padding: 0;
        grid-template-columns: 1fr;
        gap: 12px;
    }

    .hud-brand {
        justify-content: space-between;
        align-items: flex-start;
        padding-left: 2px;
    }

    .hud-brand-title-row {
        font-size: 1rem;
    }

    .hud-nav-tabs {
        justify-content: flex-start;
        overflow-x: auto;
        flex-wrap: nowrap;
        padding-bottom: 4px;
        -webkit-overflow-scrolling: touch;
    }

    .nav-tab-btn {
        flex: 0 0 auto;
        padding: 9px 12px;
        font-size: 0.73rem;
    }

    .hud-time-container {
        width: 100%;
        justify-content: space-between;
        gap: 16px;
        min-width: 0;
    }

    main.axis-workspace {
        padding: 24px 10px 34px;
    }

    .module-page.active {
        gap: 20px;
    }

    .cockpit-card {
        padding: 18px;
        gap: 16px;
        border-radius: 22px;
    }

    .cockpit-card-flat {
        border-radius: 18px;
    }

    .cockpit-header {
        font-size: 0.84rem;
        letter-spacing: 0.10em;
        padding-bottom: 12px;
    }

    .tactical-btn {
        padding: 9px 13px;
        font-size: 0.73rem;
        min-height: 38px;
    }

    .tactical-input,
    .tactical-select {
        min-height: 44px;
        padding: 12px 14px;
        font-size: 0.9rem;
        border-radius: 14px;
    }

    .live-clock-text {
        font-size: 0.98rem;
    }

    .live-date-text {
        font-size: 0.67rem;
    }

    .axis-login-panel {
        padding: 22px;
        border-radius: 26px;
    }

    .grid { gap: 16px; }
    .grid-cols-2, .grid-cols-3, .grid-cols-4 { grid-template-columns: 1fr; }
    .axis-mini-calendar { grid-template-columns: repeat(4, minmax(0, 1fr)); }

    .stat-value { font-size: 1.5rem; }
    .stat-value-lg { font-size: 2rem; }
    .text-3xl { font-size: 2.2rem; }
    .stack-lg { gap: 20px; }
}

@media (max-width: 480px) {
    header.hud-bar {
        width: calc(100% - 14px);
        margin-top: 10px;
        top: 8px;
        padding: 0;
    }

    main.axis-workspace {
        padding: 14px 8px 28px;
    }

    .module-page.active {
        gap: 16px;
    }

    .cockpit-card {
        padding: 14px;
        gap: 12px;
        border-radius: 18px;
    }

    .cockpit-card-flat {
        border-radius: 16px;
    }

    .cockpit-header {
        font-size: 0.8rem;
    }

    .tactical-btn {
        padding: 8px 11px;
        font-size: 0.68rem;
        min-height: 36px;
    }

    .tactical-input,
    .tactical-select {
        padding: 10px 12px;
        font-size: 0.86rem;
        border-radius: 12px;
    }

    .hud-nav-tabs { gap: 4px; }
    .nav-tab-btn { padding: 7px 10px; font-size: 0.66rem; }
    .boot-subline { font-size: 0.82rem; }
    .axis-mini-calendar { grid-template-columns: repeat(3, minmax(0, 1fr)); }
}


@supports (padding: max(0px)) {
    header.hud-bar {
        padding-left: max(18px, env(safe-area-inset-left));
        padding-right: max(18px, env(safe-area-inset-right));
        padding-top: max(14px, env(safe-area-inset-top));
    }

    main.axis-workspace {
        padding-left: max(12px, env(safe-area-inset-left));
        padding-right: max(12px, env(safe-area-inset-right));
    }

    @media (max-width: 900px) {
        header.hud-bar {
            padding-left: max(14px, env(safe-area-inset-left));
            padding-right: max(14px, env(safe-area-inset-right));
        }

        main.axis-workspace {
            padding-left: max(10px, env(safe-area-inset-left));
            padding-right: max(10px, env(safe-area-inset-right));
        }
    }
}

@media (prefers-reduced-motion: reduce) {
    html { scroll-behavior: auto; }
    *, *::before, *::after {
        animation: none !important;
        transition: none !important;
    }
}
